# X1SAFE V2 Environment Configuration
# Copy this file to .env and fill in your values

# Network Configuration
NETWORK=mainnet
RPC_URL=https://rpc.mainnet.x1.xyz

# Wallet (for deployment and admin)
# Use a secure wallet - hardware wallet recommended
# WALLET_PATH=/path/to/id.json
# OR
# PRIVATE_KEY=base58_encoded_key

# Token Mint Addresses (X1 Mainnet)
USDC_X_MINT=B69chRzqzDCmdB5WYB8NRu5Yv5ZA95ABiZcdzCgGm9Tq
XEN_MINT=y1KEaaWVoEfX2gH7X1Vougmc9yD1Bi2c9VHeD7bDnNC
XNT_MINT=3h3Sm8iRzV9wQM4N1kQqDm4CzRpD6o4T2yuvLVDm2wVv
XNM_MINT=XNMbEwZFFBKQhqyW3taa8cAUp1xBUHfyzRFJQvZET4m

# X1SAFE Token (deployed by the program)
# X1SAFE_MINT=... (set after initialize_vault)

# Program ID (set after deployment)
# PROGRAM_ID=...

# Oracle Configuration
ORACLE_UPDATE_INTERVAL=300000  # 5 minutes in milliseconds
PRICE_CONFIDENCE_THRESHOLD=500   # 5% in basis points

# Fee Configuration
FEE_RECIPIENT=  # Set to your fee wallet
PLATFORM_FEE_BPS=100  # 1% = 100 basis points

# Deployment Settings
ANCHOR_PROVIDER_URL=https://rpc.mainnet.x1.xyz
ANCHOR_WALLET=/path/to/deployer-keypair.json

# Optional: For CI/CD
SKIP_PREFLIGHT=false
COMMITMENT=confirmed
